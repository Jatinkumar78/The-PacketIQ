# PacketIQ environment configuration
# Copy this file to .env and fill in your real credentials — never commit .env

# ─────────────────────────────────────────────────────────
# AI COPILOT  (choose ONE — free options listed first)
# The webapp auto-detects which key is present.
# Priority: GEMINI_API_KEY > GROQ_API_KEY > ANTHROPIC_API_KEY
# ─────────────────────────────────────────────────────────

# Option 1 — Google Gemini 2.0 Flash (FREE, recommended)
# Sign up at: https://aistudio.google.com  → Get API key
# Free limits: 1,500 req/day, 1M tokens/min — more than enough
GEMINI_API_KEY="ADD YOUR KEY

# Option 2 — Groq (FREE, fastest inference)
# Sign up at: https://console.groq.com  → API Keys → Create
# Free limits: 30 req/min on Llama 3.3 70B
GROQ_API_KEY=ADD YOUR KEY

# Option 3 — Anthropic Claude (PAID — requires credits)
# Sign up at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=ADD YOUR KEY

# ─────────────────────────────────────────────────────────
# TELEGRAM ALERTS  (optional)
# Get a bot token from @BotFather on Telegram
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
